local LocalPlayer      = Players.LocalPlayer

local function getMyBase()
    local playerBases = workspace:WaitForChild("PlayerBases")
    for i = 1, 10 do
        local base = playerBases:FindFirstChild(tostring(i))
        if base then
            if base:GetAttribute("Owner") == LocalPlayer.UserId or base:GetAttribute("Owner") == LocalPlayer.Name then
                return base
            end
        end
    end
    return nil
end

local function fireBuyButton(path)
    if path and path:FindFirstChild("BuySign") then
        local btn = path.BuySign.Display.SurfaceGui.Display:FindFirstChild("BuyButton")
        if btn then ReplicatedStorage.Remotes.Base.InteractBaseButton:FireServer(btn) end
    end
end

