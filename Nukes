-- ADVANCED TAB (UNCAPPED)
Tabs.Advanced:AddToggle("DupeMoney", {Title = "Dupe Money", Default = false}):OnChanged(function()
    task.spawn(function()
        while Options.DupeMoney.Value do
            local myBase = getMyBase()
            if not myBase then break end
            local sign = myBase.Base.Machines["Manual Dropper"].Signs.LevelSign.Display.SurfaceGui.Display
            local cur = tonumber(string.match(sign.LevelLabel.Text, "%d+")) or 0
            
            local n, p, v = 3, 10, 1
            if cur >= 2 then v = cur n, p = 10, 20 end
            
            for i = 1, n do 
                if not Options.DupeMoney.Value then break end
                ReplicatedStorage.Remotes.Base.LevelUpMachine:FireServer(sign.Options.LevelUpButton, -v) 
                task.wait(0.05) 
            end
            for i = 1, p do 
                if not Options.DupeMoney.Value then break end
                ReplicatedStorage.Remotes.Base.LevelUpMachine:FireServer(sign.Options.LevelUpButton, v) 
                task.wait(0.05) 
            end
            task.wait(0.5)
        end
    end)
end)

