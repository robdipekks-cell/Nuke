local autoPlaceThread = nil
local maxTotems = 5

local function getPlacedCount()
    local base = getMyBase()
    if base and base:FindFirstChild("Base") then
        local totemFolder = base.Base:FindFirstChild("TotemComponents") 
            and base.Base.TotemComponents:FindFirstChild("PlacedTotems")
        
        if totemFolder then
            return #totemFolder:GetChildren()
        end
    end
    return 0
end

local function equipTotem()
    local backpack = LocalPlayer.Backpack
    local children = backpack:GetChildren()
    local totem = nil
    for _, item in ipairs(children) do
        if item:IsA("Tool") and (item.Name:lower():find("totem") or item.Name:lower():find("idol")) then
            totem = item
            break
        end
    end
    if not totem then
        totem = children[277] or children[#children]
    end
    if totem and LocalPlayer.Character then
        totem.Parent = LocalPlayer.Character
    end
end

local function placeTotem()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local args = { hrp.CFrame }
    local remote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Totems"):WaitForChild("PlaceTotem")
    remote:FireServer(unpack(args))
end

local function startAutoPlace()
    autoPlaceThread = task.spawn(function()
        while Options.AutoPlaceTotem.Value do
            local currentCount = getPlacedCount()
            
            if currentCount < maxTotems then
                pcall(equipTotem)
                pcall(placeTotem)
            end
            task.wait(0.1)
        end
    end)
end

Tabs.Totems:AddInput("MaxTotemsInput", {
    Title = "Max Totems Limit",
    Default = "5",
    Placeholder = "Enter number...",
    Numeric = true,
    Finished = false,
    Callback = function(Value)
        maxTotems = tonumber(Value) or 5
    end
})

Tabs.Totems:AddToggle("AutoPlaceTotem", {Title = "Auto Place", Default = false}):OnChanged(function()
    if Options.AutoPlaceTotem.Value then
        startAutoPlace()
    else
        if autoPlaceThread then task.cancel(autoPlaceThread) end
    end
end)

