Tabs.Advanced:AddToggle("AutoUpgradeDupe", {Title = "Auto Upgrade", Default = false}):OnChanged(function()
    task.spawn(function()
        while Options.AutoUpgradeDupe.Value do
            local myBase = getMyBase()
            if myBase then
                local machines = myBase.Base:FindFirstChild("Machines")
                if machines then
                    local pick = Options.AutoUpgradeMachinePick.Value

                    local function upgradeOne(machine)
                        local upgradeButtons = machine:FindFirstChild("Signs")
                            and machine.Signs:FindFirstChild("UpgradesSign")
                            and machine.Signs.UpgradesSign:FindFirstChild("Display")
                            and machine.Signs.UpgradesSign.Display:FindFirstChild("SurfaceGui")
                            and machine.Signs.UpgradesSign.Display.SurfaceGui:FindFirstChild("Display")
                            and machine.Signs.UpgradesSign.Display.SurfaceGui.Display:FindFirstChild("UpgradeButtons")

                        if upgradeButtons then
                            for _, btn in ipairs(upgradeButtons:GetChildren()) do
                                if not Options.AutoUpgradeDupe.Value then break end
                                pcall(function()
                                    ReplicatedStorage.Remotes.Base.InteractBaseButton:FireServer(btn)
                                end)
                                task.wait(0.2)
                            end
                        end
                    end

                    if pick == "All" then
                        for _, machine in ipairs(machines:GetChildren()) do
                            if not Options.AutoUpgradeDupe.Value then break end
                            upgradeOne(machine)
                        end
                    else
                        local machine = machines:FindFirstChild(pick)
                        if machine then upgradeOne(machine) end
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end)

